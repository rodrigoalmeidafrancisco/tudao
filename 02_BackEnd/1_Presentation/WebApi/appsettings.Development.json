{
  "AllowedHosts": "*",
  "Application": {
    "Build": "00000000.0",
    "Environment": "DEVELOP",
    "Release": "Release-0",
    "Name": "Tudão",
    "Policies": [
      {
        "Name": "PolicyTudao",
        "Scope": "Tudao.WebApi"
      }
    ],
    "UseProxy": "false",
    "WebUri": "https://localhost:7100"
  },
  "ApplicationInsights": {
    "InstrumentationKey": ""
  },
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=Tudao;Integrated Security=True;MultipleActiveResultSets=true;Connect Timeout=60;TrustServerCertificate=true;Encrypt=False;"
  },
  "Parameters": {

  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Services": {
    "ViaCepApi": {
      "UriCepJson": "https://viacep.com.br/ws/{cep}/json/"
    }
  }
}
