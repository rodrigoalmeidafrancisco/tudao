{
  "AllowedHosts": "*",
  "Application": {
    "Build": "",
    "Environment": "",
    "Release": "",
    "Name": "Tudão",
    "WebUri": "https://localhost:7100"
  },
  "ApplicationInsights": {
    "InstrumentationKey": ""
  },
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=Tudao;Integrated Security=True;MultipleActiveResultSets=true;Connect Timeout=60;TrustServerCertificate=true;Encrypt=False;",
  },
  "Parameters": {
    "Policies": [
      {
        "Name": "PolicyTudao",
        "Scope": "Tudao.WebApi"
      },
      {
        "Name": "PolicyTudaoExternal",
        "Scope": "Tudao.WebApi.External"
      }
    ],
    "Proxy": {
      "ByPass": [ "", "" ],
      "Enable": "false",
      "Port": "",
      "Uri": ""
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Services": {
    "ViaCepApi": {
      "UriCepJson": "https://viacep.com.br/ws/{cep}/json/"
    }
  }
}
